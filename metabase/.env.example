# Local Metabase application
METABASE_HOST_PORT=3001
METABASE_SITE_URL=http://localhost:3001
METABASE_URL=http://localhost:3001
JAVA_TIMEZONE=Asia/Ho_Chi_Minh

# Metabase metadata database. Defaults match the old local setup so existing
# pgdata can continue working.
MB_APP_DB_USER=postgres
MB_APP_DB_PASS=postgres
MB_APP_DB_NAME=postgres

# Local Metabase admin used by setup-redshift-database.sh. Change before
# sharing a demo machine.
METABASE_ADMIN_EMAIL=admin@example.com
METABASE_ADMIN_PASSWORD=ChangeThisMetabasePassword123!
METABASE_ADMIN_FIRST_NAME=DataOps
METABASE_ADMIN_LAST_NAME=Admin

# Redshift demo warehouse created by Terraform.
AWS_PROFILE=cloud-user
AWS_REGION=us-west-1
REDSHIFT_CLUSTER_IDENTIFIER=dataops-demo-cluster-dev
REDSHIFT_HOST=dataops-demo-cluster-dev.cfjdx8ilgjpc.us-west-1.redshift.amazonaws.com
REDSHIFT_PORT=5439
REDSHIFT_DATABASE=dev
REDSHIFT_SCHEMA=nyc_taxi
REDSHIFT_USERNAME=admin
REDSHIFT_PASSWORD=ReplaceWithYourTerraformRedshiftPassword
METABASE_DATABASE_NAME="Nash DataOps Redshift Dev"
